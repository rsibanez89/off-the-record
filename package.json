{
  "name": "off-the-record",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "fetch-models": "node scripts/fetch-models.mjs",
    "predev": "npm run fetch-models",
    "prebuild": "npm run fetch-models",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "bench": "rm -rf tests/integration/.bench && vitest run --config vitest.integration.config.ts && node scripts/bench-compare.mjs",
    "bench:compare": "node scripts/bench-compare.mjs",
    "bench:promote": "node scripts/bench-promote.mjs",
    "bench:matrix": "vitest run --config vitest.matrix.config.ts"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.3.3",
    "dexie": "^4.0.10",
    "dexie-react-hooks": "^1.1.7",
    "lucide-react": "^0.469.0",
    "onnxruntime-web": "1.22.0-dev.20250409-89f8206ba4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "onnxruntime-node": "^1.26.0",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^4.1.6",
    "wavefile": "^11.0.0"
  }
}
